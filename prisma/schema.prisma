// =============================================================================
// GAME SPOTLIGHT — schema.prisma
// Generado a partir del SQL existente (21 tablas) + migración 0002_dashboard_upload.
//
// Convención:
//   - Modelos en PascalCase español, campos en camelCase.
//   - Los nombres FÍSICOS (tablas/columnas) se preservan vía @@map / @map:
//     la base de datos NO cambia de nombres. Solo cambia cómo se ven en TS.
//   - Los campos de estado se mantienen como String (igual que el SQL original,
//     que usa VARCHAR sin CHECK). Los valores válidos van anotados en comentario.
//     Si más adelante quieres enums nativos de Postgres, conviértelos con un
//     enum de Prisma — pero eso implica CREATE TYPE y una migración aparte.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// CATÁLOGOS BASE
// =============================================================================

model Rol {
  idRol       String  @id @default(uuid()) @map("id_rol") @db.Uuid
  nombre      String  @unique @db.VarChar(50)
  descripcion String? @db.Text

  usuarios UsuarioRol[]

  @@map("roles")
}

model Idioma {
  idIdioma   String  @id @default(uuid()) @map("id_idioma") @db.Uuid
  codigo     String  @unique @db.VarChar(10)
  nombre     String  @db.VarChar(100)
  banderaUrl String? @map("bandera_url") @db.VarChar(255)
  activo     Boolean @default(true)

  configuraciones ConfiguracionUsuario[]

  @@map("idiomas")
}

model Plataforma {
  idPlataforma String  @id @default(uuid()) @map("id_plataforma") @db.Uuid
  nombre       String  @db.VarChar(100)
  tipo         String? @db.VarChar(50)
  iconoUrl     String? @map("icono_url") @db.VarChar(255)

  juegos JuegoPlataforma[]

  @@map("plataformas")
}

model Genero {
  idGenero    String  @id @default(uuid()) @map("id_genero") @db.Uuid
  nombre      String  @unique @db.VarChar(100)
  descripcion String? @db.Text
  iconoUrl    String? @map("icono_url") @db.VarChar(255)

  juegos JuegoGenero[]

  @@map("generos")
}

model CategoriaTrailer {
  idCategoria String @id @default(uuid()) @map("id_categoria") @db.Uuid
  nombre      String @unique @db.VarChar(100)

  trailers TrailerCategoria[]

  @@map("categorias_trailer")
}

// =============================================================================
// USUARIOS Y CUENTA
// =============================================================================

model Usuario {
  idUsuario      String    @id @default(uuid()) @map("id_usuario") @db.Uuid
  nombre         String    @db.VarChar(100)
  username       String?   @unique @db.VarChar(50) // [0002-d] login por usuario; nombre = display name
  correo         String    @unique @db.VarChar(150)
  contrasenaHash String    @map("contrasena_hash") @db.VarChar(255)
  fechaRegistro  DateTime  @default(now()) @map("fecha_registro") @db.Timestamp(6)
  ultimaSesion   DateTime? @map("ultima_sesion") @db.Timestamp(6)
  estado         Boolean   @default(true)
  avatarUrl      String?   @map("avatar_url") @db.VarChar(255)
  pais           String?   @db.VarChar(100)

  roles           UsuarioRol[]
  configuracion   ConfiguracionUsuario?
  sesiones        Sesion[]
  notificaciones  Notificacion[]
  logs            LogActividad[]
  favoritos       Favorito[]
  descargas       Descarga[]
  reservas        Reserva[]
  qrLogins        QrLogin[]
  noticiasAutor   Noticia[]    @relation("AutorNoticia")
  trailersSubidos Trailer[]    @relation("CreadorTrailer")

  @@map("usuarios")
}

model UsuarioRol {
  id              String   @id @default(uuid()) @db.Uuid
  idUsuario       String   @map("id_usuario") @db.Uuid
  idRol           String   @map("id_rol") @db.Uuid
  fechaAsignacion DateTime @default(now()) @map("fecha_asignacion") @db.Timestamp(6)

  usuario Usuario @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)
  rol     Rol     @relation(fields: [idRol], references: [idRol], onDelete: Cascade)

  @@unique([idUsuario, idRol]) // [0002-g]
  @@map("usuario_roles")
}

model ConfiguracionUsuario {
  idConfig            String   @id @default(uuid()) @map("id_config") @db.Uuid
  idUsuario           String   @unique @map("id_usuario") @db.Uuid
  idiomaId            String?  @map("idioma") @db.Uuid // FK; la columna se llama "idioma"
  tema                String?  @db.VarChar(20)
  emailNotificaciones Boolean  @default(true) @map("email_notificaciones")
  notificacionesPush  Boolean  @default(true) @map("notificaciones_push")
  privacidadPerfil    String?  @map("privacidad_perfil") @db.VarChar(20)
  // [0002-e] campos visibles en la pantalla de Ajustes
  controlParental     Boolean  @default(false) @map("control_parental")
  calidadVideo        String   @default("auto") @map("calidad_video") @db.VarChar(20) // auto | 1080p | 720p
  tamanoTexto         String   @default("normal") @map("tamano_texto") @db.VarChar(20) // normal | grande
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  usuario Usuario @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)
  idioma  Idioma? @relation(fields: [idiomaId], references: [idIdioma], onDelete: SetNull)

  @@map("configuracion_usuario")
}

model Sesion {
  idSesion    String    @id @default(uuid()) @map("id_sesion") @db.Uuid
  idUsuario   String    @map("id_usuario") @db.Uuid
  token       String    @unique @db.VarChar(255)
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent") @db.Text
  fechaInicio DateTime  @default(now()) @map("fecha_inicio") @db.Timestamp(6)
  fechaFin    DateTime? @map("fecha_fin") @db.Timestamp(6)
  activa      Boolean   @default(true)

  usuario Usuario @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)

  @@map("sesiones")
}

model Notificacion {
  idNotificacion String    @id @default(uuid()) @map("id_notificacion") @db.Uuid
  idUsuario      String    @map("id_usuario") @db.Uuid
  titulo         String    @db.VarChar(200)
  mensaje        String    @db.Text
  tipo           String?   @db.VarChar(50) // lanzamiento | trailer | alerta | mi_lista | recompensa
  leida          Boolean   @default(false)
  fechaCreacion  DateTime  @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  fechaLectura   DateTime? @map("fecha_lectura") @db.Timestamp(6)
  // [0002-f] deep link: a dónde navega el botón "Ver Tráiler" / "Ver Detalles"
  entidad        String?   @db.VarChar(50) // juego | trailer | lanzamiento | noticia
  entidadId      String?   @map("entidad_id") @db.Uuid

  usuario Usuario @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)

  @@index([idUsuario, leida]) // [0002-h] idx_notif_usuario
  @@map("notificaciones")
}

model LogActividad {
  idLog     String   @id @default(uuid()) @map("id_log") @db.Uuid
  idUsuario String?  @map("id_usuario") @db.Uuid
  accion    String   @db.VarChar(100)
  entidad   String   @db.VarChar(100)
  entidadId String?  @map("entidad_id") @db.Uuid
  detalles  Json?    @db.JsonB
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  fecha     DateTime @default(now()) @db.Timestamp(6)

  usuario Usuario? @relation(fields: [idUsuario], references: [idUsuario], onDelete: SetNull)

  @@map("logs_actividad")
}

// =============================================================================
// JUEGOS Y RELACIONES
// =============================================================================

model Juego {
  idJuego         String    @id @default(uuid()) @map("id_juego") @db.Uuid
  titulo          String    @db.VarChar(200)
  slug            String    @unique @db.VarChar(200)
  descripcion     String?   @db.Text
  fechaLanzamiento DateTime? @map("fecha_lanzamiento") @db.Date
  desarrollador   String?   @db.VarChar(150)
  editor          String?   @db.VarChar(150)
  imagenPortada   String?   @map("imagen_portada") @db.VarChar(255)
  bannerUrl       String?   @map("banner_url") @db.VarChar(255)
  estado          String?   @db.VarChar(20)
  destacado       Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  generos            JuegoGenero[]
  plataformas        JuegoPlataforma[]
  favoritos          Favorito[]
  descargas          Descarga[]
  trailers           Trailer[]
  proximoLanzamiento ProximoLanzamiento?

  @@index([destacado]) // [0002-h] idx_juegos_destacado
  @@map("juegos")
}

model JuegoGenero {
  id       String @id @default(uuid()) @db.Uuid
  idJuego  String @map("id_juego") @db.Uuid
  idGenero String @map("id_genero") @db.Uuid

  juego  Juego  @relation(fields: [idJuego], references: [idJuego], onDelete: Cascade)
  genero Genero @relation(fields: [idGenero], references: [idGenero], onDelete: Cascade)

  @@unique([idJuego, idGenero]) // [0002-g]
  @@map("juego_generos")
}

model JuegoPlataforma {
  id           String @id @default(uuid()) @db.Uuid
  idJuego      String @map("id_juego") @db.Uuid
  idPlataforma String @map("id_plataforma") @db.Uuid

  juego      Juego      @relation(fields: [idJuego], references: [idJuego], onDelete: Cascade)
  plataforma Plataforma @relation(fields: [idPlataforma], references: [idPlataforma], onDelete: Cascade)

  @@unique([idJuego, idPlataforma]) // [0002-g]
  @@map("juego_plataformas")
}

model Favorito {
  idFavorito    String   @id @default(uuid()) @map("id_favorito") @db.Uuid
  idUsuario     String   @map("id_usuario") @db.Uuid
  idJuego       String   @map("id_juego") @db.Uuid
  fechaAgregado DateTime @default(now()) @map("fecha_agregado") @db.Timestamp(6)

  usuario Usuario @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)
  juego   Juego   @relation(fields: [idJuego], references: [idJuego], onDelete: Cascade)

  @@unique([idUsuario, idJuego]) // [0002-g]
  @@map("favoritos")
}

model Descarga {
  idDescarga    String   @id @default(uuid()) @map("id_descarga") @db.Uuid
  idUsuario     String?  @map("id_usuario") @db.Uuid
  idJuego       String   @map("id_juego") @db.Uuid
  fechaDescarga DateTime @default(now()) @map("fecha_descarga") @db.Timestamp(6)
  plataforma    String?  @db.VarChar(100)

  usuario Usuario? @relation(fields: [idUsuario], references: [idUsuario], onDelete: SetNull)
  juego   Juego    @relation(fields: [idJuego], references: [idJuego], onDelete: Cascade)

  @@map("descargas")
}

model ProximoLanzamiento {
  idLanzamiento     String    @id @default(uuid()) @map("id_lanzamiento") @db.Uuid
  idJuego           String    @unique @map("id_juego") @db.Uuid
  fechaLanzamiento  DateTime? @map("fecha_lanzamiento") @db.Date
  ventanaLanzamiento String?  @map("ventana_lanzamiento") @db.VarChar(100)
  descripcion       String?   @db.Text
  bannerUrl         String?   @map("banner_url") @db.VarChar(255)
  destacado         Boolean   @default(false)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  juego    Juego     @relation(fields: [idJuego], references: [idJuego], onDelete: Cascade)
  reservas Reserva[]

  @@map("proximos_lanzamientos")
}

// =============================================================================
// TRAILERS (con soporte de subida y moderación — migración 0002)
// =============================================================================

model Trailer {
  idTrailer  String   @id @default(uuid()) @map("id_trailer") @db.Uuid
  idJuego    String   @map("id_juego") @db.Uuid
  titulo     String   @db.VarChar(200)
  tipo       String?  @db.VarChar(50)
  urlVideo   String?  @map("url_video") @db.VarChar(255) // [0002-a] ahora nullable: se llena al confirmar la subida
  urlPoster  String?  @map("url_poster") @db.VarChar(255)
  orden      Int      @default(0) @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  // [0002-a] subida por usuarios + moderación + estado de archivo en R2
  subidoPor        String? @map("subido_por") @db.Uuid
  estadoRevision   String  @default("pendiente") @map("estado_revision") @db.VarChar(20) // pendiente | aprobado | rechazado
  motivoRechazo    String? @map("motivo_rechazo") @db.Text
  estadoArchivo    String  @default("subiendo") @map("estado_archivo") @db.VarChar(20) // subiendo | disponible | error
  storageKey       String? @map("storage_key") @db.VarChar(255) // clave del objeto en R2; urlVideo se deriva de aquí
  duracionSegundos Int?    @map("duracion_segundos")
  tamanoBytes      BigInt? @map("tamano_bytes")
  vistas           Int     @default(0)

  juego      Juego              @relation(fields: [idJuego], references: [idJuego], onDelete: Cascade)
  creador    Usuario?           @relation("CreadorTrailer", fields: [subidoPor], references: [idUsuario], onDelete: SetNull)
  categorias TrailerCategoria[]

  @@index([estadoRevision]) // [0002-h] idx_trailers_revision
  @@map("trailers")
}

model TrailerCategoria {
  id          String @id @default(uuid()) @db.Uuid
  idTrailer   String @map("id_trailer") @db.Uuid
  idCategoria String @map("id_categoria") @db.Uuid

  trailer   Trailer          @relation(fields: [idTrailer], references: [idTrailer], onDelete: Cascade)
  categoria CategoriaTrailer @relation(fields: [idCategoria], references: [idCategoria], onDelete: Cascade)

  @@unique([idTrailer, idCategoria]) // [0002-g]
  @@map("trailer_categorias")
}

// =============================================================================
// NOTICIAS
// =============================================================================

model Noticia {
  idNoticia        String    @id @default(uuid()) @map("id_noticia") @db.Uuid
  titulo           String    @db.VarChar(200)
  slug             String    @unique @db.VarChar(200)
  resumen          String?   @db.Text
  contenido        String    @db.Text
  imagenPortada    String?   @map("imagen_portada") @db.VarChar(255)
  fechaPublicacion DateTime? @map("fecha_publicacion") @db.Timestamp(6)
  autorId          String?   @map("autor_id") @db.Uuid
  destacada        Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  autor    Usuario?         @relation("AutorNoticia", fields: [autorId], references: [idUsuario], onDelete: SetNull)
  imagenes ImagenNoticia[]

  @@map("noticias")
}

model ImagenNoticia {
  id        String  @id @default(uuid()) @db.Uuid
  idNoticia String  @map("id_noticia") @db.Uuid
  urlImagen String  @map("url_imagen") @db.VarChar(255)
  orden     Int     @default(0) @db.SmallInt
  leyenda   String? @db.VarChar(255)

  noticia Noticia @relation(fields: [idNoticia], references: [idNoticia], onDelete: Cascade)

  @@map("imagenes_noticias")
}

// =============================================================================
// TABLAS NUEVAS (migración 0002)
// =============================================================================

// [0002-b] Reservas de próximos lanzamientos (botón "RESERVAR AHORA" / "+")
model Reserva {
  idReserva     String   @id @default(uuid()) @map("id_reserva") @db.Uuid
  idUsuario     String   @map("id_usuario") @db.Uuid
  idLanzamiento String   @map("id_lanzamiento") @db.Uuid
  fechaReserva  DateTime @default(now()) @map("fecha_reserva") @db.Timestamp(6)

  usuario     Usuario            @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)
  lanzamiento ProximoLanzamiento @relation(fields: [idLanzamiento], references: [idLanzamiento], onDelete: Cascade)

  @@unique([idUsuario, idLanzamiento])
  @@map("reservas")
}

// [0002-c] Login con QR: la TV genera un código, el móvil lo aprueba
model QrLogin {
  codigo    String    @id @db.VarChar(8) // código corto que muestra la TV
  estado    String    @default("pendiente") @db.VarChar(20) // pendiente | aprobado | expirado
  idUsuario String?   @map("id_usuario") @db.Uuid
  creadoEn  DateTime  @default(now()) @map("creado_en") @db.Timestamp(6)
  expiraEn  DateTime  @map("expira_en") @db.Timestamp(6) // creadoEn + 5 min

  usuario Usuario? @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)

  @@map("qr_login")
}
